# Maluga Backend — Environment Variables

# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=maluga

# Or use a single connection string:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/maluga?sslmode=disable

# JWT
JWT_SECRET=maluga-dev-secret-change-in-production-min-16-chars
